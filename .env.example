# Frontend Gemini key (Vite)
VITE_GEMINI_API_KEY=your_gemini_api_key

# MongoDB Atlas Data API settings (recommended for Vercel serverless)
MONGODB_DATA_API_URL=https://data.mongodb-api.com/app/<app-id>/endpoint/data/v1
MONGODB_DATA_API_KEY=your_data_api_key
MONGODB_DATA_SOURCE=Cluster0
MONGODB_DB=proprofile

# Optional raw connection string (for driver-based deployments)
MONGODB_URI=mongodb+srv://<user>:<password>@<cluster>/<db>?retryWrites=true&w=majority
